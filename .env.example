# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=thaifordrmdb
DB_PORT=3306

# Server Configuration
PORT=5051
NODE_ENV=development

# Session Secret (keep this safe!)
SESSION_SECRET=your_session_secret_here_min_16_chars

# Comment IP Secret (keep this safe!)
COMMENT_IP_SECRET=your_comment_ip_secret_here_min_16_chars

# Proxy Configuration (set to '1' if behind proxy)
TRUST_PROXY=0

# File Upload Limits
MAX_FILE_SIZE=10485760
